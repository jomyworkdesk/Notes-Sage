CREATE TABLE E_Seller (
    
    ID INT IDENTITY(1,1) PRIMARY KEY,   -- Primary Key

    OrgID VARCHAR(50) UNIQUE,           -- Organization ID

    ElectronicAddress VARCHAR(150),     
    ElectronicSchemeID VARCHAR(50),     
    SellerIdentifier VARCHAR(100),      

    SchemeID VARCHAR(50),               

    LegalRegistrationID VARCHAR(100),   
    LegalSchemeID VARCHAR(50),          

    VATSchemeCode VARCHAR(50),          

    CountrySubdivision VARCHAR(50),     
    CountryCode VARCHAR(50),            

    LegalRegistrationType VARCHAR(50),  

    TradeLicense VARCHAR(100),          
    EmiratesID VARCHAR(50),             
    PassportNo VARCHAR(50),             

    CabinetDecision VARCHAR(100),       
    AuthorityName VARCHAR(150),         

    PassportIssuingCountry VARCHAR(50), 

    ContactEmail VARCHAR(150)           
);


CREATE TABLE E_Buyer (
    ID VARCHAR(50) PRIMARY KEY,
    IDCUST VARCHAR(50) UNIQUE,

    ElectronicAddress VARCHAR(150),
    ElectronicAddressID VARCHAR(50),

    BuyerIdentifier VARCHAR(50),
    SchemeID VARCHAR(50),

    LegalRegistrationID VARCHAR(50),
    LegalSchemeID VARCHAR(50),

    VATIdentifier VARCHAR(50),

    CountrySubdivision VARCHAR(50),
    CountryCode VARCHAR(50),

    LegalRegistrationType VARCHAR(50),

    TradeLicense VARCHAR(100),
    EmiratesID VARCHAR(50),
    PassportNo VARCHAR(50),

    CabinetDecision VARCHAR(100),
    AuthorityName VARCHAR(150),

    PassportIssuingCountry VARCHAR(50)
);
