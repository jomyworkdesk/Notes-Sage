## 🚀 **STEP-BY-STEP: CREATE A NEW API**

### **Example: Create "Get Invoices by Today" API**

#### **Step 1: Add Route**
File: `Backend/routes/invoice.js`
```javascript
router.get("/invoices/today", invoiceController.getInvoicesToday);
```

#### **Step 2: Add Controller**
File: `Backend/controllers/invoiceController.js`
```javascript
const getInvoicesToday = async (req, res) => {
    try {
        const invoices = await invoiceService.getInvoicesToday();
        return res.json({
            success: true,
            data: invoices,
            count: invoices.length
        });
    } catch (error) {
        return res.status(500).json({
            success: false,
            message: error.message
        });
    }
};

module.exports = {
    // ... existing exports
    getInvoicesToday
};
```

#### **Step 3: Add Service**
File: `Backend/services/invoiceService.js`
```javascript
const getInvoicesToday = async () => {
    const invoices = await invoiceRepository.getInvoicesToday();
    return invoices;
};

module.exports = {
    // ... existing exports
    getInvoicesToday
};
```

#### **Step 4: Add Repository**
File: `Backend/repositories/invoiceRepository.js`
```javascript
const getInvoicesToday = async () => {
    const today = new Date();
    today.setHours(0, 0, 0, 0);
    
    const tomorrow = new Date(today);
    tomorrow.setDate(tomorrow.getDate() + 1);

    return await prisma.$queryRaw`
        SELECT
            InvNumber,
            InvoiceIssueDate,
            SellerName,
            BuyerName,
            fQuantityLineTotIncl AS TotalInclusive,
            TotalTaxAmount
        FROM E_INVOICE
        WHERE InvoiceIssueDate >= ${today}
          AND InvoiceIssueDate < ${tomorrow}
        ORDER BY InvoiceIssueDate DESC
    `;
};

module.exports = {
    // ... existing exports
    getInvoicesToday
};
```

